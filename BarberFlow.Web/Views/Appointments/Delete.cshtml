@model BarberFlow.Web.Models.Entities.Appointment
@using BarberFlow.Web.Extensions

@{
    ViewData["Title"] = "Delete appointment";
}

<h1>Delete appointment</h1>

<p>Are you sure you want to delete this appointment?</p>

<div class="card" style="max-width: 40rem;">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Client</dt>
            <dd class="col-sm-9">@Model.Client.FirstName @Model.Client.LastName</dd>
            <dt class="col-sm-3">Barber</dt>
            <dd class="col-sm-9">@Model.Barber.FirstName @Model.Barber.LastName</dd>
            <dt class="col-sm-3">Service</dt>
            <dd class="col-sm-9">@Model.Service.Name</dd>
            <dt class="col-sm-3">Start</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.StartTime)</dd>
            <dt class="col-sm-3">End</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.EndTime)</dd>
            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9"><span class="badge @Model.Status.BadgeClass()">@Model.Status</span></dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <input type="submit" value="Delete" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
</form>
