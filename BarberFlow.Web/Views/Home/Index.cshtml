@model BarberFlow.Web.Models.HomeDashboardViewModel
@using BarberFlow.Web.Extensions

@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-0">Welcome to BarberFlow</h1>
        <p class="text-muted mb-0">@DateTime.Today.ToString("dddd, MMMM d, yyyy")</p>
    </div>
    <div class="btn-group">
        <a asp-controller="Appointments" asp-action="Create" class="btn btn-primary">+ New appointment</a>
        <a asp-controller="Clients" asp-action="Create" class="btn btn-outline-secondary">+ New client</a>
        <a asp-controller="Appointments" asp-action="Index" class="btn btn-outline-secondary">View full schedule</a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card h-100 text-center">
            <div class="card-body">
                <div class="display-6">@Model.TodayCount</div>
                <div class="text-muted">Today's appointments</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card h-100 text-center">
            <div class="card-body">
                <div class="display-6">@Model.WeekCount</div>
                <div class="text-muted">This week</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card h-100 text-center">
            <div class="card-body">
                <div class="display-6">@Model.ActiveClientCount</div>
                <div class="text-muted">Clients</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card h-100 text-center">
            <div class="card-body">
                <div class="display-6">@Model.BarberCount</div>
                <div class="text-muted">Barbers</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card h-100">
            <div class="card-header bg-white">
                <strong>Today's appointments</strong>
            </div>
            <div class="card-body p-0">
                @if (!Model.TodayAppointments.Any())
                {
                    <p class="text-muted p-3 mb-0">No appointments scheduled for today.</p>
                }
                else
                {
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Time</th>
                                <th>Client</th>
                                <th>Barber</th>
                                <th>Service</th>
                                <th>Status</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var appt in Model.TodayAppointments)
                            {
                                <tr>
                                    <td>@appt.StartTime.ToString("HH:mm")</td>
                                    <td>@appt.Client.FirstName @appt.Client.LastName</td>
                                    <td>@appt.Barber.FirstName @appt.Barber.LastName</td>
                                    <td>@appt.Service.Name</td>
                                    <td><span class="badge @appt.Status.BadgeClass()">@appt.Status</span></td>
                                    <td class="text-end">
                                        <a asp-controller="Appointments" asp-action="Edit" asp-route-id="@appt.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card h-100">
            <div class="card-header bg-white">
                <strong>Upcoming appointments</strong>
            </div>
            <div class="card-body p-0">
                @if (!Model.UpcomingAppointments.Any())
                {
                    <p class="text-muted p-3 mb-0">No upcoming appointments this week.</p>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var appt in Model.UpcomingAppointments)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <div>@appt.Client.FirstName @appt.Client.LastName - @appt.Service.Name</div>
                                    <small class="text-muted">@appt.StartTime.ToString("ddd MMM d, HH:mm") with @appt.Barber.FirstName @appt.Barber.LastName</small>
                                </div>
                                <span class="badge @appt.Status.BadgeClass()">@appt.Status</span>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>
