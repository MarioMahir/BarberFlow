@{
    ViewData["Title"] = "BarberFlow";
}

<div class="text-center py-5">
    <h1 class="display-5 mb-2">BarberFlow</h1>
    <p class="text-muted mb-4">Book your next haircut in a couple of clicks.</p>
    <div class="d-flex justify-content-center gap-3 flex-wrap">
        <a asp-controller="Booking" asp-action="Index" class="btn btn-primary btn-lg">Book an appointment</a>
        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary btn-lg">Staff login</a>
    </div>
</div>
