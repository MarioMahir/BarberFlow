@model IEnumerable<BarberFlow.Web.Models.Entities.BarberWorkingHour>
@{
    var barber = (BarberFlow.Web.Models.Entities.Barber)ViewData["Barber"]!;
    ViewData["Title"] = "Working Hours";
}

<div class="d-flex justify-content-between align-items-center mb-1">
    <h1 class="mb-0">Working hours</h1>
    <a asp-action="Create" asp-route-barberId="@barber.Id" class="btn btn-primary btn-sm">+ Add hours</a>
</div>
<p class="text-muted">@barber.FirstName @barber.LastName</p>

@if (!Model.Any())
{
    <p class="text-muted">No working hours configured yet. This barber cannot be booked until at least one day is added.</p>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>Day</th>
                        <th>Start</th>
                        <th>End</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.DayOfWeek</td>
                            <td>@item.StartTime.ToString("HH:mm")</td>
                            <td>@item.EndTime.ToString("HH:mm")</td>
                            <td class="text-end">
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<div class="mt-3">
    <a asp-controller="Barbers" asp-action="Details" asp-route-id="@barber.Id" class="btn btn-outline-secondary">Back to barber</a>
</div>
