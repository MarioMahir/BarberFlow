@model BarberFlow.Web.Models.Entities.BarberWorkingHour
@{
    ViewData["Title"] = "Delete Working Hours";
}

<h1>Delete working hours</h1>

<p>Are you sure you want to delete this?</p>

<div class="card" style="max-width: 30rem;">
    <div class="card-body">
        <p class="fw-semibold mb-2">@Model.Barber.FirstName @Model.Barber.LastName</p>
        <dl class="row mb-0">
            <dt class="col-sm-4">Day</dt>
            <dd class="col-sm-8">@Model.DayOfWeek</dd>
            <dt class="col-sm-4">Start</dt>
            <dd class="col-sm-8">@Model.StartTime.ToString("HH:mm")</dd>
            <dt class="col-sm-4">End</dt>
            <dd class="col-sm-8">@Model.EndTime.ToString("HH:mm")</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <input type="submit" value="Delete" class="btn btn-danger" />
    <a asp-action="Index" asp-route-barberId="@Model.BarberId" class="btn btn-outline-secondary">Cancel</a>
</form>
