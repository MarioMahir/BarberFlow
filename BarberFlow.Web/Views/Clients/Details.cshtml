@model BarberFlow.Web.Models.ClientDetailsViewModel
@using BarberFlow.Web.Extensions

@{
    ViewData["Title"] = "Client details";
}

<h1>Client details</h1>

<div class="card mb-3" style="max-width: 40rem;">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">First name</dt>
            <dd class="col-sm-9">@Model.Client.FirstName</dd>
            <dt class="col-sm-3">Last name</dt>
            <dd class="col-sm-9">@Model.Client.LastName</dd>
            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Client.Email</dd>
            <dt class="col-sm-3">Phone</dt>
            <dd class="col-sm-9">@Model.Client.PhoneNumber</dd>
        </dl>
    </div>
</div>
<div class="mb-4">
    <a asp-action="Edit" asp-route-id="@Model.Client.Id" class="btn btn-outline-secondary">Edit</a>
    <a asp-action="Index" class="btn btn-outline-secondary">Back to list</a>
</div>

<h4>Upcoming appointments</h4>
@if (!Model.UpcomingAppointments.Any())
{
    <p class="text-muted">No upcoming appointments.</p>
}
else
{
    <div class="card mb-4">
        <div class="card-body p-0">
            <table class="table table-sm mb-0">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Barber</th>
                        <th>Service</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var appt in Model.UpcomingAppointments)
                    {
                        <tr>
                            <td>@appt.StartTime.ToString("ddd MMM d, HH:mm")</td>
                            <td>@appt.Barber.FirstName @appt.Barber.LastName</td>
                            <td>@appt.Service.Name</td>
                            <td><span class="badge @appt.Status.BadgeClass()">@appt.Status</span></td>
                            <td><a asp-controller="Appointments" asp-action="Details" asp-route-id="@appt.Id" class="btn btn-sm btn-outline-secondary">Details</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<h4>Past appointments</h4>
@if (!Model.PastAppointments.Any())
{
    <p class="text-muted">No past appointments.</p>
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-sm mb-0">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Barber</th>
                        <th>Service</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var appt in Model.PastAppointments)
                    {
                        <tr>
                            <td>@appt.StartTime.ToString("ddd MMM d, HH:mm")</td>
                            <td>@appt.Barber.FirstName @appt.Barber.LastName</td>
                            <td>@appt.Service.Name</td>
                            <td><span class="badge @appt.Status.BadgeClass()">@appt.Status</span></td>
                            <td><a asp-controller="Appointments" asp-action="Details" asp-route-id="@appt.Id" class="btn btn-sm btn-outline-secondary">Details</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
