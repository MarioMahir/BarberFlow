@model BarberFlow.Web.Models.SelectBarberViewModel
@{
    ViewData["Title"] = "Choose a barber";
}

<h1>Choose a barber</h1>
<p class="text-muted">@Model.Service.Name &middot; @Model.Service.DurationMinutes min</p>

@if (!Model.Barbers.Any())
{
    <p class="text-muted">No barbers are available for booking right now.</p>
}
else
{
    <div class="row g-3">
        @foreach (var barber in Model.Barbers)
        {
            <div class="col-md-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">@barber.FirstName @barber.LastName</h5>
                        <a class="btn btn-primary" asp-action="SelectSlot" asp-route-serviceId="@Model.Service.Id" asp-route-barberId="@barber.Id">Choose</a>
                    </div>
                </div>
            </div>
        }
    </div>
}

<p class="mt-3">
    <a asp-action="Index">&laquo; Back to services</a>
</p>
