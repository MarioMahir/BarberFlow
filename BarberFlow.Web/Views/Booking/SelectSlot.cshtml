@model BarberFlow.Web.Models.SelectSlotViewModel
@{
    ViewData["Title"] = "Choose a time";
}

<h1>Choose a time</h1>
<p class="text-muted">@Model.Service.Name with @Model.Barber.FirstName @Model.Barber.LastName</p>

<div class="d-flex align-items-center gap-2 mb-3">
    @{
        var today = DateOnly.FromDateTime(DateTime.Today);
        var prevDate = Model.Date.AddDays(-1);
    }
    @if (prevDate >= today)
    {
        <a class="btn btn-outline-secondary btn-sm" asp-action="SelectSlot" asp-route-serviceId="@Model.Service.Id" asp-route-barberId="@Model.Barber.Id" asp-route-date="@prevDate.ToString("yyyy-MM-dd")">&laquo; Previous day</a>
    }
    <strong>@Model.Date.ToString("dddd, MMM d")</strong>
    <a class="btn btn-outline-secondary btn-sm" asp-action="SelectSlot" asp-route-serviceId="@Model.Service.Id" asp-route-barberId="@Model.Barber.Id" asp-route-date="@Model.Date.AddDays(1).ToString("yyyy-MM-dd")">Next day &raquo;</a>
</div>

@if (!Model.AvailableSlots.Any())
{
    <p class="text-muted">No available times this day. Try another day.</p>
}
else
{
    <div class="d-flex flex-wrap gap-2">
        @foreach (var slot in Model.AvailableSlots)
        {
            <a class="btn btn-outline-primary" asp-action="Confirm"
               asp-route-serviceId="@Model.Service.Id" asp-route-barberId="@Model.Barber.Id"
               asp-route-date="@Model.Date.ToString("yyyy-MM-dd")" asp-route-time="@slot.ToString("HH:mm")">
                @slot.ToString("HH:mm")
            </a>
        }
    </div>
}

<p class="mt-3">
    <a asp-action="SelectBarber" asp-route-serviceId="@Model.Service.Id">&laquo; Back to barbers</a>
</p>
